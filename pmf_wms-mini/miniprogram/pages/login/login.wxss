/* login.wxss */
page {
  background: #F8FAFC;
}

.login-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-header {
  width: 100%;
  height: 420rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 50%, #1E40AF 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.logo-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  backdrop-filter: blur(10px);
}

.logo-text {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.app-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  letter-spacing: 6rpx;
}

.login-card {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
  margin-top: -60rpx;
  box-shadow: 0 8rpx 40rpx rgba(37, 99, 235, 0.1);
  position: relative;
  z-index: 2;
}

.card-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 40rpx;
  text-align: center;
}

.input-group {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.input-item {
  display: flex;
  align-items: center;
  height: 100rpx;
}

.input-divider {
  height: 2rpx;
  background: #E2E8F0;
  margin: 0 10rpx;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #1E293B;
  background: transparent;
}

.input-field::placeholder {
  color: #CBD5E1;
}

.login-btn {
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  background: linear-gradient(135deg, #94A3B8, #CBD5E1);
  transition: all 0.3s;
}

.login-btn.active {
  background: linear-gradient(135deg, #2563EB, #1D4ED8);
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
}

.login-btn.active:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.login-footer {
  position: fixed;
  bottom: 60rpx;
  text-align: center;
}

.footer-text {
  font-size: 24rpx;
  color: #94A3B8;
}



.register-link:active {
  opacity: 0.6;
}

.link-text {
  color: #2563EB;
  font-weight: 500;
}