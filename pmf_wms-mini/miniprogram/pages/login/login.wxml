<view class="login-page">
  <view class="login-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="logo-circle">
        <text class="logo-text">W</text>
      </view>
      <view class="app-title">预制菜WMS</view>
      <view class="app-subtitle">仓储管理系统</view>
    </view>
  </view>
  
  <view class="login-card">
    <view class="card-title">账号登录</view>
    
    <view class="input-group">
      <view class="input-item">
        <text class="input-icon">👤</text>
        <input class="input-field" placeholder="请输入用户名" value="{{username}}" bindinput="onUsernameInput" />
      </view>
      <view class="input-divider"></view>
      <view class="input-item">
        <text class="input-icon">🔒</text>
        <input class="input-field" type="password" placeholder="请输入密码" value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>
    
    <view class="login-btn {{canLogin ? 'active' : ''}}" bindtap="handleLogin">
      <text>登 录</text>
    </view>
  </view>
  
  <view class="login-footer">
    <text class="footer-text">PMF-WMS v2.0</text>
  </view>
</view>