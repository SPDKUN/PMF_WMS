.page-container { padding: 30rpx 30rpx 120rpx; }
.form-card { background: #FFFFFF; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.form-section { margin-bottom: 20rpx; }
.form-section-title { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.form-item { padding: 20rpx 0; border-bottom: 2rpx solid #F1F5F9; }
.form-item:last-child { border-bottom: none; }
.form-label { display: block; font-size: 26rpx; color: #64748B; margin-bottom: 12rpx; }
.form-label .required { color: #F56C6C; }
.form-hint { display: block; font-size: 22rpx; color: #8B5CF6; margin-top: 8rpx; }
.form-picker { display: flex; align-items: center; justify-content: space-between; height: 64rpx; background: #F8FAFC; border-radius: 12rpx; padding: 0 20rpx; }
.form-picker text { font-size: 28rpx; color: #1E293B; }
.form-picker-text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.picker-arrow { font-size: 32rpx; color: #CBD5E1; flex-shrink: 0; }
.form-textarea { width: 100%; height: 120rpx; font-size: 28rpx; color: #1E293B; background: #F8FAFC; border-radius: 12rpx; padding: 16rpx 20rpx; box-sizing: border-box; }
.form-textarea::placeholder { color: #CBD5E1; }

.submit-area { padding: 20rpx 0; }
.submit-btn { height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; color: #FFFFFF; background: linear-gradient(135deg, #94A3B8, #CBD5E1); }
.submit-btn.active { background: linear-gradient(135deg, #8B5CF6, #7C3AED); box-shadow: 0 8rpx 24rpx rgba(139,92,246,0.3); }
.submit-btn.active:active { opacity: 0.85; transform: scale(0.98); }

page { background: #F8FAFC; }
