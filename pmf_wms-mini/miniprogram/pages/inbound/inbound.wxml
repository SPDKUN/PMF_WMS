<view class="page-container">
  <view class="page-top-bar">
    <scroll-view class="tab-scroll" scroll-x>
      <view class="tab-row">
        <view class="tab-item {{currentTab === index ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="id" data-index="{{index}}" bindtap="switchTab">
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="add-btn {{isAdmin ? '' : 'hidden'}}" bindtap="goCreate">
      <text class="add-btn-icon">+</text>
    </view>
  </view>
  
  <view class="order-list">
    <view class="order-card" wx:for="{{filteredList}}" wx:key="inbound_no" bindtap="showDetail" data-no="{{item.inbound_no}}">
      <view class="order-header">
        <view class="order-no">{{item.inbound_no}}</view>
        <text class="tag {{item.tagCls}}">{{item.order_status}}</text>
      </view>
      <view class="order-body">
        <view class="order-row">
          <text class="order-label">入库类型</text>
          <text class="order-value">{{item.inbound_type || '-'}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">创建时间</text>
          <text class="order-value">{{item.fmtCreate || '-'}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">操作人</text>
          <text class="order-value">{{item.operator_name || '-'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <text>暂无入库单</text>
  </view>
  
  <!-- 入库详情弹窗 -->
  <view class="modal-overlay {{showModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content modal-wide" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">入库单详情</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <scroll-view class="modal-body" scroll-y wx:if="{{detailItem}}">
        <view class="detail-status-bar">
          <text class="tag {{detailItem.tagCls}}" style="font-size:28rpx;padding:8rpx 24rpx;">{{detailItem.order_status}}</text>
        </view>
        <view class="info-list-card">
          <view class="info-row">
            <text class="info-label">入库单号</text>
            <text class="info-value">{{detailItem.inbound_no}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">入库类型</text>
            <text class="info-value">{{detailItem.inbound_type || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">操作人</text>
            <text class="info-value">{{detailItem.operator_name || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">创建时间</text>
            <text class="info-value">{{detailItem.fmtCreate || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">入库时间</text>
            <text class="info-value">{{detailItem.formattedTime || '-'}}</text>
          </view>
          <view class="info-row" wx:if="{{detailItem.remark}}">
            <text class="info-label">备注</text>
            <text class="info-value">{{detailItem.remark}}</text>
          </view>
        </view>
        
        <view class="section-title" style="margin-top:24rpx;">
          <text>入库明细 (<text>{{detailItems.length}}</text> 项)</text>
        </view>
        <view class="detail-item" wx:for="{{detailItems}}" wx:key="detail_id">
          <view class="detail-item-top">
            <text class="detail-item-goods">{{item.goods_name}}</text>
            <text class="detail-item-qty">x{{item.quantity}}</text>
          </view>
          <view class="detail-item-info">
            <text wx:if="{{item.batch_no}}">批次: {{item.batch_no}}</text>
            <text wx:if="{{item.location_name}}">库位: {{item.location_name}}</text>
          </view>
        </view>
        <view class="empty-state" wx:if="{{detailItems.length === 0}}" style="padding:20rpx 0;">
          <text style="font-size:24rpx;">暂无明细数据</text>
        </view>
        
        <!-- 操作按钮 -->
        <view class="detail-actions">
          <view class="detail-btn detail-btn-complete {{(detailItem.task_id && isStaff && detailItem.order_status !== '已完成') ? '' : 'hidden'}}" bindtap="completeInbound">
            <text class="btn-icon">✓</text>
            <text class="btn-text">确认执行入库</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 库位选择弹窗 -->
  <view class="modal-overlay {{showLocationPicker ? 'show' : ''}}" bindtap="cancelLocationPicker">
    <view class="modal-content modal-wide" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{locationPickerTitle}}</text>
        <text class="modal-close" bindtap="cancelLocationPicker">✕</text>
      </view>
      <scroll-view class="modal-body" scroll-y style="max-height:600rpx;">
        <view class="location-picker-list">
          <view class="loc-item {{item.isZoneHeader ? 'zone-header' : (item.checked ? 'loc-checked' : '')}}"
                wx:for="{{locationSelection}}" wx:key="_key"
                data-index="{{index}}" bindtap="toggleLocation" data-idx="{{index}}">
            <text wx:if="{{item.isZoneHeader}}" style="font-weight:bold;color:#333;">【{{item.zone_name}}】</text>
            <block wx:else>
              <text class="loc-name">{{item.location_name}}</text>
              <text class="loc-checkmark {{item.checked ? 'show' : ''}}">✓</text>
            </block>
          </view>
          <view class="empty-state" wx:if="{{locationSelection.length === 0}}" style="padding:40rpx 0;">
            <text>暂无可用库位</text>
          </view>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <view class="footer-btn footer-btn-cancel" bindtap="cancelLocationPicker">取消</view>
        <view class="footer-btn footer-btn-confirm" bindtap="confirmLocations">确认 (已选 {{selectedLocIds.length}} 个)</view>
      </view>
    </view>
  </view>
</view>
