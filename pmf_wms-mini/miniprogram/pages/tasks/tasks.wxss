/* tasks.wxss */
.page-container { padding: 0 30rpx; }

.filter-bar {
  display: flex;
  margin: 20rpx 0;
  background: #F1F5F9;
  border-radius: 40rpx;
  padding: 6rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 34rpx;
  font-size: 28rpx;
  color: #64748B;
  transition: all 0.2s;
}

.filter-item.active {
  background: #FFFFFF;
  color: #2563EB;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.task-list { margin-top: 10rpx; }

.task-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.task-card:active { transform: scale(0.98); }

.task-left { width: 8rpx; flex-shrink: 0; }
.task-priority-high { background: #EF4444; }
.task-priority-medium { background: #F59E0B; }
.task-priority-low { background: #10B981; }

.task-body { flex: 1; padding: 24rpx; }

.task-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.task-type-wrap { display: flex; align-items: center; }
.task-type-icon { font-size: 28rpx; margin-right: 8rpx; }
.task-type-text { font-size: 28rpx; font-weight: 500; color: #1E293B; }

.task-detail-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.task-detail-label { color: #94A3B8; width: 120rpx; }
.task-detail-value { color: #475569; flex: 1; }

.task-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-priority-tag {
  font-size: 22rpx;
  color: #94A3B8;
  background: #F8FAFC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.task-time {
  font-size: 22rpx;
  color: #94A3B8;
}
