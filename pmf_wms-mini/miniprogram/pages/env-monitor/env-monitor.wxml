<view class="page-container">
  <view class="env-summary">
    <view class="env-card env-temp">
      <text class="env-label">🌡️ 平均温度</text>
      <text class="env-value" wx:if="{{avgTemp}}">{{avgTemp}}<text class="env-unit">°C</text></text>
      <text class="env-value" wx:else>-</text>
    </view>
    <view class="env-card env-humid">
      <text class="env-label">💧 平均湿度</text>
      <text class="env-value" wx:if="{{avgHumidity}}">{{avgHumidity}}<text class="env-unit">%</text></text>
      <text class="env-value" wx:else>-</text>
    </view>
  </view>
  
  <view class="section-title">
    <text>监测记录</text>
  </view>
  
  <view class="record-list">
    <view class="record-card" wx:for="{{list}}" wx:key="record_id">
      <view class="record-top">
        <text class="record-warehouse">🏭 库房 #{{item.warehouse_id}}</text>
        <text class="record-time">{{item.fmtTime}}</text>
      </view>
      <view class="record-data">
        <view class="record-item temp">
          <text class="record-item-icon">🌡️</text>
          <text class="record-item-value">{{item.temperature || '-'}}°C</text>
        </view>
        <view class="record-item humid">
          <text class="record-item-icon">💧</text>
          <text class="record-item-value">{{item.humidity || '-'}}%</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="empty-state" wx:if="{{list.length === 0}}">
    <text>暂无监测记录</text>
  </view>
</view>
