<view class="page-container">
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">新增批次</text>
    </view>
    <view class="form-item">
      <text class="form-label">选择货物</text>
      <picker mode="selector" range="{{goodsList}}" range-key="goods_name" bindchange="onGoodsChange">
        <view class="form-picker"><text>{{goodsName || '请选择货物'}}</text><text class="picker-arrow">›</text></view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">生产日期</text>
      <picker mode="date" bindchange="onDateInput" data-field="production_date">
        <view class="form-picker"><text>{{production_date || '请选择日期'}}</text><text class="picker-arrow">›</text></view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">到期日期</text>
      <picker mode="date" bindchange="onDateInput" data-field="expiry_date">
        <view class="form-picker"><text>{{expiry_date || '请选择日期'}}</text><text class="picker-arrow">›</text></view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">初始数量</text>
      <input class="form-input" type="number" placeholder="输入数量" value="{{initial_quantity}}" bindinput="onQtyInput" />
    </view>
  </view>
  <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="handleSubmit">
    <text>创建批次</text>
  </view>
</view>