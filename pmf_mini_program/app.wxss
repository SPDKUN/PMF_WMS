/* app.wxss - 全局样式 */
@import "styles/theme.wxss";

/* 统一盒模型 */
page {
  --nav-bar-height: 88rpx;
  --status-bar-height: 0;
  --tab-bar-height: 100rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
  background-color: var(--bg-primary);
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* 全局文本溢出处理 - 所有页面统一 */
page view,
page text,
page scroll-view {
  box-sizing: border-box;
}

/* 容器 */
.page-container {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.page-content {
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin: 30rpx 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title .more-link {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 400;
}

/* 卡片 */
.card {
  background: var(--bg-card);
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

/* 状态标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 1.8;
}

.tag-success { background: #DCFCE7; color: #166534; }
.tag-warning { background: #FEF3C7; color: #92400E; }
.tag-danger { background: #FEE2E2; color: #991B1B; }
.tag-info { background: #DBEAFE; color: #1E40AF; }
.tag-default { background: #F1F5F9; color: #475569; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

.empty-state .empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

/* 加载 */
.loading-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* 分隔线 */
.divider {
  height: 2rpx;
  background: var(--border);
  margin: 20rpx 0;
}

/* 列表项 */
.list-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

.list-item .label {
  color: var(--text-secondary);
  width: 160rpx;
  flex-shrink: 0;
  font-size: 26rpx;
}

.list-item .value {
  flex: 1;
  color: var(--text-primary);
  font-size: 28rpx;
  text-align: right;
}

/* 主按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(37, 99, 235, 0.3);
  transition: all 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 次要按钮 */
.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: var(--bg-secondary);
  color: var(--primary);
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: 2rpx solid var(--primary);
}

.btn-secondary:active {
  opacity: 0.7;
}

/* 安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom, 0);
}

/* ===== 全局 UI 优化 ===== */

/* 文本自动换行通用类 */
.text-break {
  word-break: break-all;
  overflow-wrap: break-word;
  word-wrap: break-word;
}

/* 长文本溢出省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 详情字段行 - 统一解决文字间距过大问题 */
.detail-field-row {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}
.detail-field-label {
  width: 160rpx;
  flex-shrink: 0;
  font-size: 26rpx;
  color: #94A3B8;
}
.detail-field-value {
  flex: 1;
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
  word-break: break-all;
  overflow-wrap: break-word;
  text-align: left;
}

/* 页面背景统一 */
page {
  background-color: #F8FAFC;
}
