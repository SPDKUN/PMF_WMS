<!-- 注册页 -->
<view class="register-page">
  <view class="register-header">
    <view class="title">创建账号</view>
    <view class="subtitle">加入PMF智能仓储管理系统</view>
  </view>

  <view class="register-form">
    <view class="form-group">
      <view class="form-label">用户名 <text class="text-danger">*</text></view>
      <input class="form-input" placeholder="请输入用户名" value="{{form.username}}" data-field="username" bindinput="onInput" />
    </view>

    <view class="form-group">
      <view class="form-label">真实姓名 <text class="text-danger">*</text></view>
      <input class="form-input" placeholder="请输入真实姓名" value="{{form.real_name}}" data-field="real_name" bindinput="onInput" />
    </view>

    <view class="form-group">
      <view class="form-label">手机号 <text class="text-danger">*</text></view>
      <input class="form-input" type="number" placeholder="请输入手机号" value="{{form.phone}}" data-field="phone" bindinput="onInput" />
    </view>

    <view class="form-group">
      <view class="form-label">密码 <text class="text-danger">*</text></view>
      <input class="form-input" type="password" placeholder="请输入密码（至少6位）" value="{{form.password}}" data-field="password" bindinput="onInput" />
    </view>

    <view class="form-group">
      <view class="form-label">确认密码 <text class="text-danger">*</text></view>
      <input class="form-input" type="password" placeholder="请再次输入密码" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
    </view>

    <button class="register-btn" bindtap="handleRegister" loading="{{loading}}">注 册</button>

    <view class="login-link" bindtap="goToLogin">
      已有账号？<text class="text-primary">立即登录</text>
    </view>
  </view>
</view>
