<view class="page-container">
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">出库信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">选择货物 <text class="required">*</text></text>
      <picker mode="selector" range="{{goodsDisplayList}}" bindchange="onGoodsChange">
        <view class="form-picker">
          <text>{{selectedGoods ? selectedGoods.goods_name + ' (' + selectedGoods.goods_code + ')' : '请选择货物'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <text class="form-hint" wx:if="{{goodsStockInfo}}">{{goodsStockInfo}}</text>
    </view>
    <view class="form-item" wx:if="{{selectedGoods}}">
      <text class="form-label">选择批次 <text class="required">*</text></text>
      <picker mode="selector" range="{{batchDisplayList}}" bindchange="onBatchChange">
        <view class="form-picker">
          <text class="form-picker-text">{{selectedBatchDisplay || '请选择批次'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item" wx:if="{{selectedBatch && locationDisplayList.length > 0}}">
      <text class="form-label">选择库位 <text class="required">*</text></text>
      <picker mode="selector" range="{{locationDisplayList}}" bindchange="onLocationChange">
        <view class="form-picker">
          <text class="form-picker-text">{{selectedLocationDisplay || '请选择库位'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <text class="form-hint" wx:if="{{selectedLocation}}">该批次在各库位的库存分布，请选择出库的库位</text>
    </view>
    <view class="form-item" wx:if="{{selectedBatch && locationDisplayList.length === 0}}">
      <text class="form-label" style="color:#EF4444;font-size:24rpx;">未找到已入库的库位记录，请先完成入库</text>
    </view>
    <view class="form-item">
      <text class="form-label">出库数量</text>
      <input class="form-input" type="number" placeholder="输入数量" value="{{quantity}}" bindinput="onQtyInput" />
    </view>
    <view class="form-item">
      <text class="form-label">执行人 <text class="required">*</text></text>
      <picker mode="selector" range="{{userList}}" range-key="real_name" bindchange="onOperatorChange">
        <view class="form-picker">
          <text>{{operatorName || '请选择执行人'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">任务设置</text>
    </view>
    <view class="form-item">
      <text class="form-label">优先级 <text class="required">*</text></text>
      <picker mode="selector" range="{{priorities}}" bindchange="onPriorityChange">
        <view class="form-picker">
          <text>{{priority || '请选择优先级'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">截止日期</text>
      <picker mode="date" bindchange="onDateChange">
        <view class="form-picker">
          <text>{{deadline || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="submit-area">
    <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="handleSubmit">
      <text>创建出库任务</text>
    </view>
  </view>
</view>
