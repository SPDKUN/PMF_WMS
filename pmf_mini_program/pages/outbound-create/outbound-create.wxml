<view class="page-container">
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">出库信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">选择货物 <text class="required">*</text></text>
      <picker mode="selector" range="{{goodsDisplayList}}" bindchange="onGoodsChange">
        <view class="form-picker">
          <text>{{selectedGoods ? selectedGoods.goods_name + ' (' + (selectedGoods.goods_code || '') + ')' : '请选择货物'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>

    <!-- 库存表格（多行选择） -->
    <view wx:if="{{inventoryRows.length > 0}}" class="inv-table-section">
      <view class="inv-table-header">
        <text class="inv-th inv-th-batch">批次</text>
        <text class="inv-th inv-th-loc">位置</text>
        <text class="inv-th inv-th-expiry">到期日期</text>
        <text class="inv-th inv-th-avail">可出库</text>
        <text class="inv-th inv-th-qty">选择数量</text>
      </view>
      <view class="inv-table-row" wx:for="{{inventoryRows}}" wx:key="inventory_id">
        <text class="inv-td inv-td-batch">{{item.batch_id || '-'}}</text>
        <text class="inv-td inv-td-loc">{{item.location_name || '-'}}</text>
        <text class="inv-td inv-td-expiry">{{item.expiry_date || '-'}}</text>
        <text class="inv-td inv-td-avail">{{item.available}}</text>
        <view class="inv-td inv-td-qty">
          <input class="inv-qty-input" type="number" min="0" max="{{item.available}}" value="{{item.selectQty}}" data-index="{{index}}" bindinput="onQtyInput" />
        </view>
      </view>
      <view class="inv-table-total">
        <text>已选总数量：<text class="total-num">{{outboundTotalSelected || 0}}</text></text>
      </view>
    </view>
    <view wx:elif="{{selectedGoods && inventoryRows.length === 0}}" class="inv-empty">
      <text>该货物暂无可用库存</text>
    </view>
  </view>

  <!-- 创建信息 -->
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">创建信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">创建人</text>
      <view class="form-picker form-readonly">
        <text class="form-readonly-text">{{creatorName || '未登录'}}</text>
      </view>
    </view>
    <view class="form-item">
      <text class="form-label">创建时间</text>
      <view class="form-picker form-readonly">
        <text class="form-readonly-text">{{createTime || '-'}}</text>
      </view>
    </view>
  </view>

  <!-- 任务设置 -->
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">任务设置</text>
    </view>
    <view class="form-item">
      <text class="form-label">负责人 <text class="required">*</text></text>
      <picker mode="selector" range="{{userList}}" range-key="real_name" bindchange="onOperatorChange">
        <view class="form-picker">
          <text>{{assigneeName || '请选择负责人'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">优先级 <text class="required">*</text></text>
      <picker mode="selector" range="{{priorities}}" bindchange="onPriorityChange">
        <view class="form-picker">
          <text>{{priority || '请选择优先级'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">截至日期 <text class="required">*</text></text>
      <picker mode="date" bindchange="onDateChange">
        <view class="form-picker">
          <text>{{deadline || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="submit-area">
    <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="handleSubmit">
      <text>创建出库任务</text>
    </view>
  </view>
</view>
