.page-container { padding: 30rpx 30rpx 120rpx; }
.form-card { background: #FFFFFF; border-radius: 20rpx; padding: 30rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.form-section { margin-bottom: 20rpx; }
.form-section-title { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.form-item { padding: 20rpx 0; border-bottom: 2rpx solid #F1F5F9; }
.form-item:last-child { border-bottom: none; }
.form-label { display: block; font-size: 26rpx; color: #64748B; margin-bottom: 12rpx; }
.form-label .required { color: #F56C6C; }
.form-hint { display: block; font-size: 22rpx; color: #2563EB; margin-top: 8rpx; }
.form-input {
  width: 100%; height: 64rpx; font-size: 30rpx; color: #1E293B;
  background: #F8FAFC; border-radius: 12rpx; padding: 0 20rpx; box-sizing: border-box;
}
.form-input::placeholder { color: #CBD5E1; }
.form-picker {
  display: flex; align-items: center; justify-content: space-between;
  height: 64rpx; background: #F8FAFC; border-radius: 12rpx; padding: 0 20rpx;
}
.form-picker text { font-size: 28rpx; color: #1E293B; }
.form-picker-text { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.picker-arrow { font-size: 32rpx; color: #CBD5E1; flex-shrink: 0; }
.form-readonly { background: #F0F4FF; }
.form-readonly-text { color: #3B82F6; font-weight: 500; }

.submit-area { padding: 20rpx 0; }
.submit-btn { height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; color: #FFFFFF; background: linear-gradient(135deg, #94A3B8, #CBD5E1); }
.submit-btn.active { background: linear-gradient(135deg, #2563EB, #1D4ED8); box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.3); }
.submit-btn.active:active { opacity: 0.85; transform: scale(0.98); }

/* 库存表格 */
.inv-table-section { margin-top: 16rpx; }
.inv-table-header {
  display: flex; align-items: center;
  padding: 14rpx 8rpx; background: #F1F5F9; border-radius: 10rpx 10rpx 0 0;
}
.inv-th { font-size: 22rpx; color: #64748B; font-weight: 600; text-align: center; }
.inv-th-batch { flex: 2; }
.inv-th-loc { flex: 2; }
.inv-th-expiry { flex: 2; }
.inv-th-avail { flex: 1.5; }
.inv-th-qty { flex: 1.5; }

.inv-table-row {
  display: flex; align-items: center;
  padding: 16rpx 8rpx; border-bottom: 2rpx solid #F1F5F9;
  background: #FFFFFF;
}
.inv-table-row:last-child { border-bottom: none; border-radius: 0 0 10rpx 10rpx; }
.inv-td { font-size: 24rpx; color: #334155; text-align: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.inv-td-batch { flex: 2; }
.inv-td-loc { flex: 2; }
.inv-td-expiry { flex: 2; }
.inv-td-avail { flex: 1.5; }
.inv-td-qty { flex: 1.5; display: flex; justify-content: center; }

.inv-qty-input {
  width: 80rpx; height: 48rpx; font-size: 24rpx; color: #1E293B;
  background: #F8FAFC; border: 2rpx solid #E2E8F0; border-radius: 8rpx;
  text-align: center; padding: 0 4rpx;
}

.inv-table-total {
  text-align: right; padding: 14rpx 8rpx;
  font-size: 24rpx; font-weight: 600; color: #334155;
  background: #F8FAFC; border-radius: 0 0 10rpx 10rpx;
}
.total-num { color: #2563EB; font-size: 28rpx; }

.inv-empty {
  text-align: center; padding: 24rpx; font-size: 24rpx; color: #94A3B8;
}

page { background: #F8FAFC; }
