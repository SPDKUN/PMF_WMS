.dashboard-page {
  height: 100vh;
  background: #F1F5F9;
  padding: 20rpx;
}

.chart-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.chart-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

/* canvas 容器 */
.chart-canvas-wrap {
  width: 100%;
  height: 360rpx;
  position: relative;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 透明触摸覆盖层 */
.chart-touch-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 10;
}

/* 横向滚动容器 */
.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.chart-scroll-inner {
  height: 360rpx;
  display: inline-block;
  position: relative;
}

.chart-scroll-inner .chart-canvas {
  height: 100%;
}

/* 容量饱和度 */
.capacity-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.capacity-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.capacity-label {
  width: 180rpx;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.capacity-name {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.capacity-num {
  font-size: 22rpx;
  color: #94A3B8;
}

.progress-bar {
  flex: 1;
  height: 20rpx;
  background: #F1F5F9;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.6s ease;
}

.capacity-percent {
  width: 80rpx;
  font-size: 24rpx;
  color: #475569;
  text-align: right;
  flex-shrink: 0;
}

.empty-hint {
  text-align: center;
  color: #94A3B8;
  padding: 60rpx 0;
  font-size: 26rpx;
}

/* tooltip 浮层 — 绝对定位在图表容器内 */
.chart-tip {
  position: absolute;
  z-index: 20;
  background: rgba(30, 41, 59, 0.9);
  color: #fff;
  font-size: 22rpx;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  pointer-events: none;
  opacity: 0;
  transform: translate(-50%, -100%);
  transition: opacity 0.15s;
  white-space: pre-line;
  max-width: 300rpx;
  text-align: center;
}
.chart-tip.show { opacity: 1; }
