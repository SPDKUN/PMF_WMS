<view class="page-container">
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">入库信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">入库类型 <text class="required">*</text></text>
      <picker mode="selector" range="{{inboundTypes}}" bindchange="onTypeChange">
        <view class="form-picker">
          <text>{{inboundType || '请选择入库类型'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">批次号 <text class="required">*</text></text>
      <picker mode="selector" range="{{batchList}}" range-key="batchDisplay" bindchange="onBatchChange">
        <view class="form-picker">
          <text class="form-picker-text">{{batchDisplay || '请选择批次'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">执行人 <text class="required">*</text></text>
      <picker mode="selector" range="{{userList}}" range-key="real_name" bindchange="onOperatorChange">
        <view class="form-picker">
          <text>{{operatorName || '请选择执行人'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>

  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">任务设置</text>
    </view>
    <view class="form-item">
      <text class="form-label">优先级 <text class="required">*</text></text>
      <picker mode="selector" range="{{priorities}}" bindchange="onPriorityChange">
        <view class="form-picker">
          <text>{{priority || '请选择优先级'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">截止日期</text>
      <picker mode="date" bindchange="onDateChange">
        <view class="form-picker">
          <text>{{deadline || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="选填" value="{{remark}}" bindinput="onInput" data-field="remark" />
    </view>
  </view>

  <view class="submit-area">
    <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="handleSubmit">
      <text>创建入库任务</text>
    </view>
  </view>
</view>
