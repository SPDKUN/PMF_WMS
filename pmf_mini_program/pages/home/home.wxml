<scroll-view class="home-page" scroll-y>
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{navBarHeight}}px;">
    <view class="nav-content">
      <view class="nav-left">
        <text class="nav-greeting">你好，{{userInfo.real_name || '用户'}}</text>
        <text class="nav-date">{{currentDate}}</text>
      </view>
      <view class="nav-right">
        <view class="nav-icon-wrap" bindtap="toggleNotifications">
          <text class="nav-icon">🔔</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 通知弹窗 -->
  <view class="notif-overlay {{showNotifications ? 'show' : ''}}" bindtap="toggleNotifications">
    <view class="notif-panel" catchtap="stopPropagation">
      <view class="notif-header">
        <text class="notif-title">消息通知</text>
        <text class="notif-close" bindtap="toggleNotifications">✕</text>
      </view>
      <scroll-view class="notif-body" scroll-y>
        <view class="notif-item" wx:for="{{notifications}}" wx:key="id">
          <text class="notif-icon">{{item.icon}}</text>
          <view class="notif-content">
            <text class="notif-item-title">{{item.title}}</text>
            <text class="notif-desc">{{item.desc}}</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
  
  <!-- 统计卡片 -->
  <view class="stats-row">
    <view class="stat-card" wx:for="{{stats}}" wx:key="id" bindtap="onStatTap" data-index="{{index}}">
      <view class="stat-icon" style="background: {{item.bgColor}}">
        <text>{{item.icon}}</text>
      </view>
      <text class="stat-number">{{item.count}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>
  
  <!-- AI智能助手 -->
  <view class="ai-assistant" bindtap="openAiAssistant">
    <view class="ai-left">
      <view class="ai-avatar">
        <text>🤖</text>
      </view>
      <view class="ai-info">
        <text class="ai-title">AI 智能助手</text>
        <text class="ai-desc">点击咨询仓储相关问题</text>
      </view>
    </view>
    <text class="ai-arrow">›</text>
  </view>
  
  <!-- 快捷功能 -->
  <view class="section-wrap">
    <view class="section-header">
      <text class="section-title">快捷功能</text>
    </view>
    <view class="quick-grid">
      <view class="quick-item" wx:for="{{quickActions}}" wx:key="id" bindtap="onQuickAction" data-page="{{item.page}}" data-need-perm="{{item.needPerm}}" data-is-tab="{{item.isTab}}">
        <view class="quick-icon" style="background: {{item.bgColor}}">
          <text>{{item.icon}}</text>
        </view>
        <text class="quick-label">{{item.label}}</text>
      </view>
    </view>
  </view>
  
  <!-- 待办任务 -->
  <view class="section-wrap">
    <view class="section-header">
      <text class="section-title">待办任务</text>
      <text class="section-more" bindtap="goTasks">查看更多 ›</text>
    </view>
    <view class="task-card" wx:for="{{recentTasks}}" wx:key="task_id">
      <view class="task-priority priority-{{item.priority === '高' ? 'high' : item.priority === '中' ? 'medium' : 'low'}}"></view>
      <view class="task-body">
        <view class="task-top">
          <text class="task-type">{{item.task_type}}</text>
          <text class="task-tag {{item.task_status === '已完成' ? 'tag-success' : item.task_status === '进行中' ? 'tag-warning' : 'tag-info'}}">{{item.task_status || '待处理'}}</text>
        </view>
        <view class="task-info">
          <text class="task-detail" wx:if="{{item.related_order_no}}">单号：{{item.related_order_no}}</text>
          <text class="task-deadline">截止：{{item.deadline || '-'}}</text>
        </view>
      </view>
    </view>
    <view class="empty-state" wx:if="{{recentTasks.length === 0}}">
      <text class="empty-text">暂无待办任务</text>
    </view>
  </view>
</scroll-view>
  <!-- 权限提示弹窗 -->
  <view class="modal-overlay {{showPermModal ? 'show' : ''}}" bindtap="closePermModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">提示</text>
        <text class="modal-close" bindtap="closePermModal">✕</text>
      </view>
      <view class="modal-body">
        <text class="modal-msg">{{permModalMsg}}</text>
      </view>
      <view class="modal-footer">
        <view class="modal-btn" bindtap="closePermModal">确定</view>
      </view>
    </view>
  </view>

  <!-- AI对话框 -->
  <view class="ai-chat-overlay {{showAiChat ? 'show' : ''}}" bindtap="closeAiChat">
    <view class="ai-chat-panel" catchtap="stopPropagation">
      <view class="ai-chat-header">
        <text class="ai-chat-title">AI 智能助手</text>
        <text class="ai-chat-close" bindtap="closeAiChat">✕</text>
      </view>
      <scroll-view class="ai-chat-body" scroll-y>
        <view class="ai-msg {{item.role === 'user' ? 'user-msg' : 'ai-msg-item'}}" wx:for="{{aiMessages}}" wx:key="role">
          <view wx:if="{{item.role === 'ai'}}" class="msg-avatar">🤖</view>
          <view class="msg-bubble">{{item.text}}</view>
          <view wx:if="{{item.role === 'user'}}" class="msg-avatar">👤</view>
        </view>
        <view class="ai-msg ai-msg-item" wx:if="{{aiLoading}}">
          <view class="msg-avatar">🤖</view>
          <view class="msg-bubble thinking">思考中...</view>
        </view>
      </scroll-view>
      <view class="ai-chat-footer">
        <input class="ai-input" placeholder="输入您的问题..." value="{{aiInput}}" bindinput="onAiInput" confirm-type="send" bindconfirm="sendAiMessage" />
        <view class="ai-send-btn {{aiInput.trim() && !aiLoading ? 'active' : ''}}" bindtap="sendAiMessage">发送</view>
      </view>
    </view>
  </view>
