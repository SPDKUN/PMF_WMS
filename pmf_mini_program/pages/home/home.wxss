.home-page {
  height: 100vh;
  padding-top: 50rpx;
  background: #EBF4FF;
}
/* home.wxss */
.home-page {
  height: 100vh;
  background: #EBF4FF;
}

/* 导航栏 */
.nav-bar {
  background: linear-gradient(135deg, #2563EB 0%, #1D4ED8 60%, #1E40AF 100%);
  padding: 0 30rpx 60rpx;
  border-radius: 0 0 60rpx 60rpx;
}

.nav-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 10rpx;
}

.nav-left {
  display: flex;
  flex-direction: column;
}

.nav-greeting {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.nav-date {
  font-size: 24rpx;
  color: rgba(255,255,255,0.7);
}

.nav-right {
  display: flex;
  align-items: center;
}

.nav-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 36rpx;
  background: rgba(255,255,255,0.15);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 32rpx;
}

/* 缁熻鍗＄墖 */
.stats-row {
  display: flex;
  padding: 0 20rpx;
  margin-top: -40rpx;
  position: relative;
  z-index: 2;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  margin: 0 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.stat-card:active {
  transform: scale(0.95);
}

.stat-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
  font-size: 28rpx;
}

.stat-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 区域 */
.section-wrap {
  padding: 30rpx 30rpx 0;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1E293B;
}

.section-more {
  font-size: 26rpx;
  color: #2563EB;
}

/* 快捷功能网格 */
.quick-grid {
  display: flex;
  flex-wrap: wrap;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 0;
}

.quick-item:active {
  opacity: 0.6;
}

.quick-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #475569;
  text-align: center;
}

/* 任务卡片 */
.task-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  min-height: 120rpx;
}

.task-card:active {
  transform: scale(0.98);
}

.task-priority {
  width: 8rpx;
  flex-shrink: 0;
}

.priority-high { background: #EF4444; }
.priority-medium { background: #F59E0B; }
.priority-low { background: #10B981; }

.task-body {
  flex: 1;
  padding: 24rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.task-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.task-type {
  font-size: 28rpx;
  font-weight: 500;
  color: #1E293B;
}

.task-tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.task-info {
  display: flex;
  justify-content: space-between;
}

.task-detail, .task-deadline {
  font-size: 24rpx;
  color: #94A3B8;
}

.empty-state {
  padding: 40rpx 0;
  display: flex;
  justify-content: center;
}

.empty-text {
  font-size: 28rpx;
  color: #94A3B8;
}

/* 通知弹窗 */
.notif-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.3); z-index: 999;
  display: none; align-items: flex-start; justify-content: flex-end;
  padding-top: 100rpx; padding-right: 20rpx;
}
.notif-overlay.show { display: flex; }
.notif-panel {
  width: 500rpx; max-height: 600rpx;
  background: #FFFFFF; border-radius: 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.12);
  overflow: hidden; animation: notifIn 0.2s ease;
}
@keyframes notifIn {
  from { transform: translateY(-20rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}
.notif-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 24rpx 28rpx; border-bottom: 2rpx solid #F1F5F9;
}
.notif-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.notif-close { font-size: 28rpx; color: #94A3B8; padding: 8rpx; }
.notif-body { padding: 12rpx 0; max-height: 480rpx; }
.notif-item {
  display: flex; align-items: flex-start;
  padding: 20rpx 28rpx; border-bottom: 2rpx solid #F8FAFC;
}
.notif-icon { font-size: 32rpx; margin-right: 16rpx; margin-top: 4rpx; }
.notif-content { flex: 1; }
.notif-item-title { font-size: 26rpx; font-weight: 500; color: #1E293B; display: block; margin-bottom: 4rpx; }
.notif-desc { font-size: 22rpx; color: #94A3B8; display: block; }

/* AI助手小窗口 */
.ai-assistant {
  margin: 20rpx 30rpx 0;
  background: linear-gradient(135deg, #EEF2FF 0%, #E0E7FF 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border: 2rpx solid #C7D2FE;
}
.ai-assistant:active { opacity: 0.8; }
.ai-left { display: flex; align-items: center; }
.ai-avatar {
  width: 64rpx; height: 64rpx; border-radius: 32rpx;
  background: linear-gradient(135deg, #6366F1, #4F46E5);
  display: flex; align-items: center; justify-content: center;
  margin-right: 16rpx;
}
.ai-avatar text { font-size: 28rpx; color: #FFFFFF; }
.ai-info { }
.ai-title { font-size: 26rpx; font-weight: 600; color: #1E293B; display: block; }
.ai-desc { font-size: 22rpx; color: #6366F1; display: block; margin-top: 4rpx; }
.ai-arrow { font-size: 32rpx; color: #6366F1; }

.ai-chat-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 1000;
  display: none; align-items: center; justify-content: center;
}
.ai-chat-overlay.show { display: flex; }
.ai-chat-panel {
  width: 620rpx; height: 75vh; background: #FFFFFF;
  border-radius: 24rpx; overflow: hidden;
  display: flex; flex-direction: column; animation: modalIn 0.25s ease;
}
@keyframes modalIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
.ai-chat-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; border-bottom: 2rpx solid #F1F5F9;
  background: linear-gradient(135deg, #EEF2FF, #E0E7FF);
}
.ai-chat-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.ai-chat-close { font-size: 28rpx; color: #94A3B8; padding: 8rpx; }
.ai-chat-body { flex: 1; padding: 20rpx 24rpx; overflow-y: auto; background: #F8FAFC; }
.ai-msg { display: flex; align-items: flex-start; margin-bottom: 20rpx; }
.ai-msg.user-msg { justify-content: flex-end; }
.msg-avatar { width: 48rpx; height: 48rpx; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; flex-shrink: 0; }
.ai-msg-item .msg-avatar { margin-right: 12rpx; }
.user-msg .msg-avatar { margin-left: 12rpx; }
.msg-bubble { max-width: 70%; padding: 16rpx 20rpx; border-radius: 12rpx; font-size: 26rpx; line-height: 1.6; word-break: break-all; }
.ai-msg-item .msg-bubble { background: #FFFFFF; color: #1E293B; border: 2rpx solid #E2E8F0; }
.user-msg .msg-bubble { background: #2563EB; color: #FFFFFF; }
.msg-bubble.thinking { color: #94A3B8; }
.ai-chat-footer { display: flex; align-items: center; padding: 20rpx 24rpx; border-top: 2rpx solid #F1F5F9; background: #FFFFFF; }
.ai-input { flex: 1; height: 64rpx; background: #F1F5F9; border-radius: 32rpx; padding: 0 24rpx; font-size: 26rpx; }
.ai-send-btn { width: 100rpx; height: 64rpx; border-radius: 32rpx; display: flex; align-items: center; justify-content: center; margin-left: 16rpx; font-size: 26rpx; font-weight: 500; background: #2563EB; color: #FFFFFF; flex-shrink: 0; }
.ai-send-btn.active { background: #2563EB; color: #FFFFFF; }

/* 通用弹窗样式 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.35); z-index: 1100;
  display: none; align-items: center; justify-content: center;
}
.modal-overlay.show { display: flex; }
.modal-content {
  width: 560rpx; background: #FFFFFF; border-radius: 24rpx;
  overflow: hidden; animation: modalIn 0.25s ease;
}
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; border-bottom: 2rpx solid #F1F5F9;
}
.modal-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.modal-close { font-size: 28rpx; color: #94A3B8; padding: 8rpx; }
.modal-body {
  padding: 40rpx 32rpx; display: flex; align-items: center; justify-content: center;
}
.modal-msg { font-size: 28rpx; color: #475569; text-align: center; line-height: 1.6; }
.modal-footer {
  display: flex; justify-content: center; padding: 16rpx 32rpx 32rpx;
}
.modal-btn {
  background: #2563EB; color: #FFFFFF; font-size: 28rpx; font-weight: 500;
  padding: 16rpx 64rpx; border-radius: 40rpx;
}
.modal-btn:active { opacity: 0.8; }
