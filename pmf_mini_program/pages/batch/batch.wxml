<view class="page-container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索批次号/货物名称" value="{{searchKeyword}}" bindinput="onSearchInput" confirm-type="search" />
    <text class="search-clear {{searchKeyword ? 'show' : ''}}" bindtap="onSearchClear">✕</text>
  </view>

  <view class="page-top-bar">
    <view class="page-title-area">
      <text class="page-title-text">批次列表</text>
    </view>
    <view class="add-btn" bindtap="goCreate" wx:if="{{isManager}}">
      <text class="add-btn-icon">+</text>
    </view>
  </view>
  
  <view class="batch-list">
    <view class="batch-card" wx:for="{{filteredList}}" wx:key="batch_id" bindtap="showDetail" data-id="{{item.batch_id}}">
      <view class="batch-top">
        <view class="batch-id-wrap">
          <text class="batch-id-label">批次号</text>
          <text class="batch-id-value">{{item.batch_id}}</text>
        </view>
        <text class="tag {{item.tagCls}}">{{item.batch_status}}</text>
      </view>
      
      <view class="batch-body">
        <view class="batch-info-row">
          <text class="batch-info-label">货物名称</text>
          <text class="batch-info-value">{{item.goods_name}}</text>
        </view>
        <view class="batch-info-row">
          <text class="batch-info-label">生产日期</text>
          <text class="batch-info-value">{{item.fmtProd || '-'}}</text>
        </view>
        <view class="batch-info-row">
          <text class="batch-info-label">到期日期</text>
          <text class="batch-info-value">{{item.fmtExp || '-'}}</text>
        </view>
      </view>
      
      <view class="batch-qty-row">
        <view class="batch-qty-item">
          <text class="batch-qty-label">初始数量</text>
          <text class="batch-qty-value">{{item.initial_quantity}}</text>
        </view>
        <view class="batch-qty-divider"></view>
        <view class="batch-qty-item">
          <text class="batch-qty-label">剩余数量</text>
          <text class="batch-qty-value" style="color: #2563EB;">{{item.remaining_quantity}}</text>
        </view>
      </view>
      
      <view class="batch-progress">
        <view class="batch-progress-bar">
          <view class="batch-progress-fill" style="width: {{item.progress}}%;"></view>
        </view>
        <text class="batch-progress-text">{{item.progress}}% 已消耗</text>
      </view>
    </view>
  </view>
  
  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <text>暂无批次数据</text>
  </view>
  
  <!-- 批次详情弹窗 -->
  <view class="modal-overlay {{showModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content modal-wide" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">批次详情</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <scroll-view class="modal-body" scroll-y wx:if="{{detailItem}}">
        <view class="detail-status-bar">
          <text class="tag {{detailItem.tagCls}}" style="font-size:28rpx;padding:8rpx 24rpx;">{{detailItem.batch_status}}</text>
        </view>
        
        <!-- 批次基本信息 -->
        <view class="section-title">基本信息</view>
        <view class="info-list-card" style="margin-bottom:20rpx;">
          <view class="info-row">
            <text class="info-label">批次号</text>
            <text class="info-value">{{detailItem.batch_id}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">货物名称</text>
            <text class="info-value">{{detailItem.goods_name}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">生产日期</text>
            <text class="info-value">{{detailItem.fmtProd}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">到期日期</text>
            <text class="info-value">{{detailItem.fmtExp}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">初始数量</text>
            <text class="info-value">{{detailItem.initial_quantity}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">剩余数量</text>
            <text class="info-value" style="color:#2563EB;">{{detailItem.remaining_quantity}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">消耗进度</text>
            <text class="info-value">{{detailItem.progress}}%</text>
          </view>
        </view>
        
        <!-- 库存情况 -->
        <view class="section-title">库存情况</view>
        <view class="info-list-card" style="margin-bottom:20rpx;" wx:if="{{batchInventory.length > 0}}">
          <view class="detail-sub-item" wx:for="{{batchInventory}}" wx:key="location_name">
            <view class="detail-sub-row">
              <text class="detail-sub-label">库位</text>
              <text class="detail-sub-value">{{item.location_name}}</text>
            </view>
            <view class="detail-sub-row">
              <text class="detail-sub-label">数量</text>
              <text class="detail-sub-value">{{item.quantity}}</text>
            </view>
            <view class="detail-sub-row">
              <text class="detail-sub-label">状态</text>
              <text class="detail-sub-value">{{item.inventory_status}}</text>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{batchInventory.length === 0}}" style="padding:16rpx 0;">
          <text style="font-size:24rpx;">暂无库存记录</text>
        </view>
        
        <!-- 质检情况 -->
        <view class="section-title">质检记录</view>
        <view class="info-list-card" wx:if="{{batchQcRecords.length > 0}}">
          <view class="detail-sub-item" wx:for="{{batchQcRecords}}" wx:key="quality_check_no">
            <view class="detail-sub-row">
              <text class="detail-sub-label">质检单</text>
              <text class="detail-sub-value">{{item.quality_check_no}}</text>
            </view>
            <view class="detail-sub-row">
              <text class="detail-sub-label">类型</text>
              <text class="detail-sub-value">{{item.check_type}}</text>
            </view>
            <view class="detail-sub-row">
              <text class="detail-sub-label">结果</text>
              <text class="detail-sub-value" style="color: {{item.inspection_result === '合格' ? '#67C23A' : (item.inspection_result === '不合格' ? '#F56C6C' : '#94A3B8')}};">{{item.inspection_result || '待检'}}</text>
            </view>
          </view>
        </view>
        <view class="empty-state" wx:if="{{batchQcRecords.length === 0}}" style="padding:16rpx 0;">
          <text style="font-size:24rpx;">暂无质检记录</text>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
