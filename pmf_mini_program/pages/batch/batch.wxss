/* batch.wxss */
.page-container { padding: 0 30rpx 40rpx; }

/* 搜索栏 */
.search-bar {
  display: flex; align-items: center; background: #FFFFFF; border-radius: 16rpx;
  padding: 16rpx 24rpx; margin: 20rpx 0 0; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.search-icon { font-size: 28rpx; margin-right: 16rpx; }
.search-input { flex: 1; font-size: 26rpx; color: #1E293B; height: 40rpx; }
.search-input::placeholder { color: #94A3B8; }
.search-clear { font-size: 28rpx; color: #94A3B8; padding: 8rpx; display: none; }
.search-clear.show { display: block; }

.page-top-bar { display: flex; align-items: center; justify-content: space-between; margin: 16rpx 0; }
.page-title-area { flex: 1; }
.page-title-text { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.add-btn { width: 64rpx; height: 64rpx; border-radius: 32rpx; background: #2563EB; display: flex; align-items: center; justify-content: center; flex-shrink: 0; box-shadow: 0 4rpx 12rpx rgba(37,99,235,0.3); }
.add-btn:active { transform: scale(0.9); }
.add-btn-icon { font-size: 36rpx; color: #FFFFFF; font-weight: 300; }

.batch-card { background: #FFFFFF; border-radius: 16rpx; padding: 28rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.batch-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.batch-id-wrap { display: flex; flex-direction: column; flex: 1; }
.batch-id-label { font-size: 22rpx; color: #94A3B8; margin-bottom: 4rpx; }
.batch-id-value { font-size: 28rpx; font-weight: 700; color: #1E293B; word-break: break-all; }
.tag { font-size: 20rpx; padding: 6rpx 16rpx; border-radius: 8rpx; flex-shrink: 0; }
.tag-success { background: #F0F9EB; color: #67C23A; }
.tag-warning { background: #FDF6EC; color: #E6A23C; }
.tag-danger { background: #FEF0F0; color: #F56C6C; }
.tag-info { background: #EFF6FF; color: #2563EB; }
.tag-default { background: #F1F5F9; color: #64748B; }

.batch-body { margin-bottom: 20rpx; padding-bottom: 20rpx; border-bottom: 2rpx solid #F1F5F9; }
.batch-info-row { display: flex; padding: 6rpx 0; }
.batch-info-label { width: 140rpx; flex-shrink: 0; font-size: 26rpx; color: #94A3B8; }
.batch-info-value { font-size: 26rpx; color: #475569; word-break: break-all; overflow-wrap: break-word; flex: 1; }

.batch-qty-row { display: flex; align-items: center; margin-bottom: 20rpx; }
.batch-qty-item { flex: 1; text-align: center; }
.batch-qty-divider { width: 2rpx; height: 40rpx; background: #E2E8F0; }
.batch-qty-label { display: block; font-size: 22rpx; color: #94A3B8; margin-bottom: 6rpx; }
.batch-qty-value { font-size: 36rpx; font-weight: 700; color: #1E293B; }
.batch-progress { display: flex; align-items: center; }
.batch-progress-bar { flex: 1; height: 12rpx; background: #F1F5F9; border-radius: 6rpx; overflow: hidden; margin-right: 16rpx; }
.batch-progress-fill { height: 100%; background: linear-gradient(90deg, #60A5FA, #2563EB); border-radius: 6rpx; }
.batch-progress-text { font-size: 22rpx; color: #94A3B8; flex-shrink: 0; }

/* 弹窗 */
.modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 1000; display: none; align-items: center; justify-content: center; }
.modal-overlay.show { display: flex; }
.modal-content { width: 580rpx; max-height: 80vh; background: #FFFFFF; border-radius: 24rpx; overflow: hidden; display: flex; flex-direction: column; }
.modal-wide { width: 640rpx; }
@keyframes modalIn { from { transform: scale(0.9); opacity: 0; } to { transform: scale(1); opacity: 1; } }
.modal-header { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; border-bottom: 2rpx solid #F1F5F9; flex-shrink: 0; }
.modal-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.modal-close { font-size: 36rpx; color: #94A3B8; padding: 10rpx; }
.modal-close:active { opacity: 0.5; }
.modal-body { padding: 24rpx 32rpx 32rpx; flex: 1; height: 0; overflow-y: auto; }

.detail-status-bar { margin-bottom: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1E293B; margin-bottom: 12rpx; }

.info-list-card { background: #F8FAFC; border-radius: 16rpx; overflow: hidden; }
.info-row { display: flex; align-items: flex-start; padding: 18rpx 24rpx; border-bottom: 2rpx solid #F1F5F9; }
.info-row:last-child { border-bottom: none; }
.info-label { width: 160rpx; flex-shrink: 0; font-size: 26rpx; color: #94A3B8; }
.info-value { flex: 1; font-size: 26rpx; color: #1E293B; font-weight: 500; word-break: break-all; overflow-wrap: break-word; text-align: left; }

/* 子项明细 */
.detail-sub-item { padding: 12rpx 24rpx; border-bottom: 2rpx solid #F1F5F9; }
.detail-sub-item:last-child { border-bottom: none; }
.detail-sub-row { display: flex; padding: 4rpx 0; }
.detail-sub-label { width: 120rpx; flex-shrink: 0; font-size: 24rpx; color: #94A3B8; }
.detail-sub-value { flex: 1; font-size: 24rpx; color: #475569; word-break: break-all; }

.empty-state { text-align: center; padding: 60rpx 0; color: #94A3B8; font-size: 26rpx; }
page { background: #F8FAFC; }
