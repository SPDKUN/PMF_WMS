<view class="page-container">
  <view class="page-top-bar">
    <scroll-view class="tab-scroll" scroll-x>
      <view class="tab-row">
        <view class="tab-item {{currentTab === index ? 'active' : ''}}" wx:for="{{tabs}}" wx:key="id" data-index="{{index}}" bindtap="switchTab">
          <text>{{item}}</text>
        </view>
      </view>
    </scroll-view>
    <view class="add-btn {{isAdmin ? '' : 'hidden'}}" bindtap="goCreate">
      <text class="add-btn-icon">+</text>
    </view>
  </view>
  
  <view class="order-list">
    <view class="order-card" wx:for="{{filteredList}}" wx:key="outbound_no" bindtap="showDetail" data-no="{{item.outbound_no}}">
      <view class="order-header">
        <view class="order-no">{{item.outbound_no}}</view>
        <text class="tag {{item.tagCls}}">{{item.order_status}}</text>
      </view>
      <view class="order-body">
        <view class="order-row">
          <text class="order-label">出库类型</text>
          <text class="order-value">{{item.outbound_type || '-'}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">创建时间</text>
          <text class="order-value">{{item.fmtCreate || '-'}}</text>
        </view>
        <view class="order-row">
          <text class="order-label">操作人</text>
          <text class="order-value">{{item.operator_name || '-'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="empty-state" wx:if="{{filteredList.length === 0}}">
    <text>暂无出库单</text>
  </view>
  
  <!-- 出库详情弹窗 -->
  <view class="modal-overlay {{showModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content modal-wide" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">出库单详情</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <scroll-view class="modal-body" scroll-y wx:if="{{detailItem}}">
        <view class="detail-status-bar">
          <text class="tag {{detailItem.tagCls}}" style="font-size:28rpx;padding:8rpx 24rpx;">{{detailItem.order_status}}</text>
        </view>
        <view class="info-list-card">
          <view class="info-row">
            <text class="info-label">出库单号</text>
            <text class="info-value">{{detailItem.outbound_no}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">出库类型</text>
            <text class="info-value">{{detailItem.outbound_type || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">操作人</text>
            <text class="info-value">{{detailItem.operator_name || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">创建时间</text>
            <text class="info-value">{{detailItem.fmtCreate || '-'}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">出库时间</text>
            <text class="info-value">{{detailItem.formattedTime || '-'}}</text>
          </view>
          <view class="info-row" wx:if="{{detailItem.remark}}">
            <text class="info-label">备注</text>
            <text class="info-value">{{detailItem.remark}}</text>
          </view>
        </view>
        
        <view class="section-title" style="margin-top:24rpx;">
          <text>出库明细 (<text>{{detailItems.length}}</text> 项)</text>
        </view>
        <view class="detail-item" wx:for="{{detailItems}}" wx:key="detail_id">
          <view class="detail-item-top">
            <text class="detail-item-goods">{{item.goods_name}}</text>
            <text class="detail-item-qty">x{{item.quantity}}</text>
          </view>
          <view class="detail-item-info">
            <text wx:if="{{item.batch_id}}">批次: {{item.batch_id}}</text>
            <text wx:if="{{item.location_name}}">来源库位: {{item.location_name}}</text>
          </view>
        </view>
        <view class="empty-state" wx:if="{{detailItems.length === 0}}" style="padding:20rpx 0;">
          <text style="font-size:24rpx;">暂无明细数据</text>
        </view>
        
        <view class="detail-actions">
          <view class="detail-btn detail-btn-complete {{(detailItem.task_id && isStaff && detailItem.order_status !== '已完成') ? '' : 'hidden'}}" bindtap="completeOutbound">
            <text class="btn-icon">✓</text>
            <text class="btn-text">确认执行出库</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>
