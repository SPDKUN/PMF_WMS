.page-container { padding: 0 30rpx 40rpx; }
.form-card { background: #FFFFFF; border-radius: 16rpx; padding: 24rpx; margin-top: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); }
.form-section { margin-bottom: 20rpx; }
.form-section-title { font-size: 30rpx; font-weight: 600; color: #1E293B; }
.form-item { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 2rpx solid #F8FAFC; }
.form-item:last-child { border-bottom: none; }
.form-label { font-size: 28rpx; color: #475569; flex-shrink: 0; margin-right: 20rpx; }
.form-input { flex: 1; text-align: right; font-size: 28rpx; color: #1E293B; height: 56rpx; }
.form-picker { flex: 1; display: flex; justify-content: flex-end; align-items: center; }
.form-picker text { font-size: 28rpx; color: #94A3B8; }
.picker-arrow { font-size: 36rpx; color: #CBD5E1; margin-left: 8rpx; }
.submit-btn { height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 30rpx; font-weight: 600; color: #FFFFFF; background: linear-gradient(135deg, #94A3B8, #CBD5E1); margin-top: 40rpx; }
.submit-btn.active { background: linear-gradient(135deg, #2563EB, #1D4ED8); box-shadow: 0 8rpx 24rpx rgba(37,99,235,0.3); }
.submit-btn:active { opacity: 0.85; transform: scale(0.98); }