/* 任务页样式 */
.tasks-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
}

.tab-content {
  padding-bottom: 100rpx;
}

/* 操作中心 */
.section-title {
  font-size: 32rpx;
  color: #303133;
  padding: 0 10rpx;
}

.operation-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.op-card {
  width: calc(50% - 10rpx);
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.op-card:active {
  transform: scale(0.96);
  background: #f5f7fa;
}

.op-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.op-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 8rpx;
}

.op-desc {
  font-size: 24rpx;
  color: #909399;
}

.picker-input {
  display: flex;
  align-items: center;
}
