/* tasks.wxss */
.page-container { padding: 0 30rpx; }

.filter-bar {
  display: flex;
  margin: 20rpx 0;
  background: #F1F5F9;
  border-radius: 40rpx;
  padding: 6rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 34rpx;
  font-size: 28rpx;
  color: #64748B;
  transition: all 0.2s;
}

.filter-item.active {
  background: #FFFFFF;
  color: #2563EB;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.task-list { margin-top: 10rpx; }

.task-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.task-card:active { transform: scale(0.98); }

.task-left { width: 8rpx; flex-shrink: 0; }
.task-priority-high { background: #EF4444; }
.task-priority-medium { background: #F59E0B; }
.task-priority-low { background: #10B981; }

.task-body { flex: 1; padding: 24rpx; }

.task-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.task-type-wrap { display: flex; align-items: center; }
.task-type-icon { font-size: 28rpx; margin-right: 8rpx; }
.task-type-text { font-size: 28rpx; font-weight: 500; color: #1E293B; }

.task-detail-row {
  display: flex;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.task-detail-label { color: #94A3B8; width: 120rpx; }
.task-detail-value { color: #475569; flex: 1; }

.task-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.task-priority-tag {
  font-size: 22rpx;
  color: #94A3B8;
  background: #F8FAFC;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.task-time {
  font-size: 22rpx;
  color: #94A3B8;
}

/* 标签 */
.tag {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.tag-success { background: #F0FDF4; color: #16A34A; }
.tag-warning { background: #FEF3C7; color: #D97706; }
.tag-info { background: #DBEAFE; color: #2563EB; }
.tag-danger { background: #FEF2F2; color: #DC2626; }
.tag-default { background: #F8FAFC; color: #94A3B8; }

.empty-state {
  padding: 80rpx 0;
  text-align: center;
  color: #94A3B8;
  font-size: 28rpx;
}

/* 详情弹窗 */
.modal-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4); z-index: 1100;
  display: none; align-items: center; justify-content: center;
}
.modal-overlay.show { display: flex; }

.detail-modal {
  width: 680rpx;
  max-height: 85vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  animation: modalSlideIn 0.25s ease;
}

@keyframes modalSlideIn {
  from { transform: translateY(40rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 28rpx 32rpx; border-bottom: 2rpx solid #F1F5F9;
  flex-shrink: 0;
}
.modal-title { font-size: 32rpx; font-weight: 600; color: #1E293B; }
.modal-close { font-size: 28rpx; color: #94A3B8; padding: 8rpx; }

.modal-body {
  flex: 1;
  padding: 24rpx 32rpx;
  overflow-y: auto;
  max-height: 55vh;
}

.modal-footer {
  padding: 16rpx 32rpx 28rpx;
  border-top: 2rpx solid #F1F5F9;
  display: flex;
  justify-content: center;
  flex-shrink: 0;
}

.modal-btn-cancel {
  padding: 16rpx 64rpx;
  background: #F1F5F9;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #475569;
}
.modal-btn-cancel:active { background: #E2E8F0; }

/* 详情区域 */
.detail-section {
  margin-bottom: 24rpx;
}

.detail-section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
  display: block;
}

/* 头部信息网格 */
.detail-head-grid {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.detail-head-item {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}
.detail-head-item:last-child { border-bottom: none; }

.detail-head-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.detail-head-value {
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 500;
}

/* 明细表格 */
.detail-table-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.detail-table {
  min-width: 100%;
}

.detail-table-header {
  display: flex;
  background: #F8FAFC;
  border-radius: 8rpx 8rpx 0 0;
  padding: 14rpx 0;
  white-space: nowrap;
}

.detail-th {
  flex: 1;
  min-width: 100rpx;
  text-align: center;
  font-size: 20rpx;
  font-weight: 600;
  color: #64748B;
  padding: 0 6rpx;
}

.detail-table-row {
  display: flex;
  border-bottom: 1rpx solid #F1F5F9;
  padding: 12rpx 0;
  white-space: nowrap;
}

.detail-td {
  flex: 1;
  min-width: 100rpx;
  text-align: center;
  font-size: 20rpx;
  color: #475569;
  padding: 0 6rpx;
  word-break: break-all;
}

.detail-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #94A3B8;
  font-size: 24rpx;
}
