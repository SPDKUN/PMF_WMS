/* 查询页样式 */
.query-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
}

.tabs-scroll {
  white-space: nowrap;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  padding: 10rpx 0;
}

.tabs-scroll .tab-item {
  display: inline-block;
  padding: 18rpx 30rpx;
  font-size: 26rpx;
  color: #606266;
  border-bottom: 4rpx solid transparent;
}

.tabs-scroll .tab-item.active {
  color: #409eff;
  border-bottom-color: #409eff;
  font-weight: bold;
}

.tab-content {
  padding-bottom: 20rpx;
}

/* 明细行 */
.detail-row {
  padding: 12rpx 0;
  font-size: 28rpx;
  color: #303133;
  border-bottom: 1rpx solid #f5f7fa;
}

.detail-row:last-child {
  border-bottom: none;
}

.detail-label {
  color: #909399;
  margin-right: 12rpx;
  min-width: 140rpx;
  display: inline-block;
}

/* 筛选行 */
.filter-row {
  display: flex;
  align-items: center;
}

.filter-input {
  flex: 1;
  height: 68rpx;
  background: #fff;
  border: 2rpx solid #e4e7ed;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
}
