/* 个人中心样式 */
.profile-page {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 20rpx;
}

.profile-header {
  background: linear-gradient(135deg, #409eff 0%, #2d6cdf 100%);
  border-radius: 20rpx;
  padding: 50rpx 36rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  color: #fff;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.profile-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 4rpx;
}

.profile-username {
  font-size: 26rpx;
  opacity: 0.8;
  margin-bottom: 6rpx;
}

/* 信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #909399;
}

.info-value {
  font-size: 28rpx;
  color: #303133;
  text-align: right;
}

/* 分隔线 */
.section-divider {
  padding: 16rpx 0;
  text-align: center;
  border-top: 1rpx dashed #e4e7ed;
}

/* 退出登录 */
.logout-section {
  padding: 40rpx 0;
}

.logout-btn {
  width: 100%;
  height: 88rpx;
  background: #fff;
  color: #f56c6c;
  font-size: 30rpx;
  border: 2rpx solid #f56c6c;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
