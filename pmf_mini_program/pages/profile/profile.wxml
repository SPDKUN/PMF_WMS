<view class="profile-page">
  <view class="profile-header">
    <view class="profile-avatar" bindtap="showUserInfo">
      <text class="avatar-text">{{avatarText}}</text>
    </view>
    <text class="profile-name" bindtap="showUserInfo">{{userInfo.real_name || '用户'}}</text>
    <view class="profile-meta" bindtap="showUserInfo">
      <text class="profile-dept">{{userInfo.department || '未设置部门'}}</text>
      <text class="profile-divider">|</text>
      <text class="profile-pos">{{userInfo.position || '未设置职位'}}</text>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="menu-item" bindtap="goMyTasks">
      <text class="menu-icon">📋</text>
      <text class="menu-label">我的任务</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-divider"></view>
    <view class="menu-item" bindtap="goAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-label">关于系统</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>
  
  <view class="logout-btn" bindtap="handleLogout">
    <text>退出登录</text>
  </view>
  
  <!-- 用户信息弹窗 -->
  <view class="modal-overlay {{showModal ? 'show' : ''}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">个人信息</text>
        <text class="modal-close" bindtap="closeModal">✕</text>
      </view>
      <view class="modal-body">
        <view class="modal-avatar-wrap">
          <view class="modal-avatar">
            <text class="modal-avatar-text">{{avatarText}}</text>
          </view>
          <text class="modal-user-name">{{userInfo.real_name || '-'}}</text>
        </view>
        <view class="modal-info-list">
          <view class="modal-info-item">
            <text class="modal-info-label">用户名</text>
            <text class="modal-info-value">{{userInfo.username || '-'}}</text>
          </view>
          <view class="modal-info-item">
            <text class="modal-info-label">姓名</text>
            <text class="modal-info-value">{{userInfo.real_name || '-'}}</text>
          </view>
          <view class="modal-info-item">
            <text class="modal-info-label">部门</text>
            <text class="modal-info-value">{{userInfo.department || '-'}}</text>
          </view>
          <view class="modal-info-item">
            <text class="modal-info-label">职位</text>
            <text class="modal-info-value">{{userInfo.position || '-'}}</text>
          </view>
          <view class="modal-info-item">
            <text class="modal-info-label">手机号</text>
            <text class="modal-info-value">{{userInfo.phone || '-'}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>