<view class="page-container">
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">质检信息</text>
    </view>
    <view class="form-item">
      <text class="form-label">质检类型 <text class="required">*</text></text>
      <picker mode="selector" range="{{checkTypes}}" bindchange="onTypeChange">
        <view class="form-picker">
          <text>{{checkType || '请选择质检类型'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">关联批次 <text class="required">*</text></text>
      <picker mode="selector" range="{{batchList}}" range-key="display" bindchange="onBatchChange">
        <view class="form-picker">
          <text class="form-picker-text">{{batchDisplay || '请选择批次'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
      <text class="form-hint" wx:if="{{checkType}}">
        {{checkType === '来料检' ? '仅显示未入库批次' : '仅显示已入库批次'}}
      </text>
    </view>
    <view class="form-item">
      <text class="form-label">质检员 <text class="required">*</text></text>
      <picker mode="selector" range="{{inspectorList}}" range-key="real_name" bindchange="onInspectorChange">
        <view class="form-picker">
          <text>{{inspectorName || '请选择质检员'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
  </view>
  <view class="form-card">
    <view class="form-section">
      <text class="form-section-title">任务设置</text>
    </view>
    <view class="form-item">
      <text class="form-label">优先级 <text class="required">*</text></text>
      <picker mode="selector" range="{{priorities}}" bindchange="onPriorityChange">
        <view class="form-picker">
          <text>{{priority || '请选择优先级'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">截止日期</text>
      <picker mode="date" bindchange="onDateChange">
        <view class="form-picker">
          <text>{{deadline || '请选择日期'}}</text>
          <text class="picker-arrow">›</text>
        </view>
      </picker>
    </view>
    <view class="form-item">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="选填" value="{{remark}}" bindinput="onInput" data-field="remark" />
    </view>
  </view>
  <view class="submit-area">
    <view class="submit-btn {{canSubmit ? 'active' : ''}}" bindtap="handleSubmit">
      <text>创建质检任务</text>
    </view>
  </view>
</view>
