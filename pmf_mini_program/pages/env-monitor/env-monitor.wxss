/* env-monitor.wxss */
.page-container { padding: 0 30rpx; }

.env-summary {
  display: flex;
  margin: 20rpx 0;
  gap: 20rpx;
}

.env-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
}

.env-temp {
  background: linear-gradient(135deg, #DBEAFE, #EFF6FF);
}

.env-humid {
  background: linear-gradient(135deg, #DCFCE7, #F0FDF4);
}

.env-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
}

.env-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #1E293B;
}

.env-unit {
  font-size: 28rpx;
  font-weight: 400;
  color: #94A3B8;
}

.record-list {
  margin-top: 10rpx;
}

.record-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.record-top {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.record-warehouse {
  font-size: 28rpx;
  font-weight: 500;
  color: #475569;
}

.record-time {
  font-size: 24rpx;
  color: #94A3B8;
}

.record-data {
  display: flex;
  gap: 30rpx;
}

.record-item {
  display: flex;
  align-items: center;
  flex: 1;
}

.record-item-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.record-item-value {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}

.record-item.temp .record-item-value { color: #2563EB; }
.record-item.humid .record-item-value { color: #10B981; }

/* 上传表单卡片 */
.upload-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.upload-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #F1F5F9;
}

.form-item {
  margin-bottom: 16rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.required {
  color: #F56C6C;
}

.form-row {
  display: flex;
  gap: 20rpx;
}

.form-half {
  flex: 1;
}

.picker-wrap {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1E293B;
}

.picker-wrap .placeholder {
  color: #94A3B8;
}

.picker-arrow {
  font-size: 20rpx;
  color: #94A3B8;
}

.form-input {
  width: 100%;
  padding: 16rpx 20rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #1E293B;
  box-sizing: border-box;
}

.upload-btn {
  background: linear-gradient(135deg, #2563EB, #1D4ED8);
  border-radius: 12rpx;
  padding: 20rpx 0;
  text-align: center;
  margin-top: 8rpx;
}

.upload-btn:active {
  opacity: 0.8;
}

.upload-btn text {
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: 600;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
  margin-bottom: 16rpx;
}

.empty-state {
  padding: 60rpx 0;
  text-align: center;
  color: #94A3B8;
  font-size: 26rpx;
}
