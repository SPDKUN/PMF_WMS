/* 登录页样式 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #409eff 0%, #337ecc 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 60rpx;
}

.login-header {
  text-align: center;
  margin-top: 180rpx;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 12rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 36rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

.login-form {
  width: 100%;
  background: #fff;
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.login-form .form-group {
  margin-bottom: 36rpx;
}

.login-form .form-label {
  font-size: 28rpx;
  color: #303133;
  margin-bottom: 14rpx;
}

.login-form .form-input {
  height: 88rpx;
  background: #f5f7fa;
  border: 2rpx solid #e4e7ed;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 30rpx;
}

.login-form .form-input:focus {
  border-color: #409eff;
  background: #fff;
}

.login-btn {
  width: 100%;
  height: 90rpx;
  background: #409eff;
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 12rpx;
  border: none;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn:active {
  background: #3a8ee6;
}

.login-btn[loading] {
  opacity: 0.7;
}

.error-msg {
  margin-top: 24rpx;
  padding: 18rpx 24rpx;
  background: #fef0f0;
  border: 2rpx solid #fde2e2;
  border-radius: 8rpx;
  color: #f56c6c;
  font-size: 26rpx;
  text-align: center;
}

.register-link {
  text-align: center;
  margin-top: 32rpx;
  font-size: 28rpx;
  color: #909399;
}

.login-footer {
  position: absolute;
  bottom: 60rpx;
  text-align: center;
}
