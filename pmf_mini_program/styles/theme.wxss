/* theme.wxss - 主题变量 */
page {
  /* 主色调 - 专业蓝 */
  --primary: #2563EB;
  --primary-light: #60A5FA;
  --primary-dark: #1D4ED8;
  
  /* 辅助色 */
  --secondary: #0EA5E9;
  --accent: #8B5CF6;
  
  /* 语义色 */
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;
  --info: #3B82F6;
  
  /* 背景色 */
  --bg-primary: #F8FAFC;
  --bg-card: #FFFFFF;
  --bg-secondary: #F1F5F9;
  --bg-tertiary: #E2E8F0;
  
  /* 文字色 */
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --text-placeholder: #CBD5E1;
  
  /* 边框 */
  --border: #E2E8F0;
  --border-light: #F1F5F9;
  
  /* 圆角 */
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  
  /* 阴影 */
  --shadow-sm: 0 2rpx 8rpx rgba(0,0,0,0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0,0,0,0.06);
  --shadow-lg: 0 8rpx 32rpx rgba(0,0,0,0.08);
}
