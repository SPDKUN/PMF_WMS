<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.pmf.mapper.AdjustmentOrderDetailMapper">

    <resultMap id="AdjustmentOrderDetailMap" type="com.neuedu.pmf.entity.AdjustmentOrderDetail">
        <id column="detail_id" property="detail_id"/>
        <result column="adjustment_no" property="adjustment_no"/>
        <result column="goods_id" property="goods_id"/>
        <result column="batch_id" property="batch_id"/>
        <result column="quantity" property="quantity"/>
        <result column="from_warehouse_id" property="from_warehouse_id"/>
        <result column="from_zone_id" property="from_zone_id"/>
        <result column="from_location_id" property="from_location_id"/>
        <result column="to_warehouse_id" property="to_warehouse_id"/>
        <result column="to_zone_id" property="to_zone_id"/>
        <result column="to_location_id" property="to_location_id"/>
    </resultMap>

    <select id="list" resultMap="AdjustmentOrderDetailMap">
        SELECT * FROM adjustment_order_detail
    </select>

    <select id="findById" resultMap="AdjustmentOrderDetailMap">
        SELECT * FROM adjustment_order_detail WHERE detail_id = #{detail_id}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="detail_id">
        INSERT INTO adjustment_order_detail (adjustment_no, goods_id, batch_id, quantity, from_warehouse_id, from_zone_id, from_location_id, to_warehouse_id, to_zone_id, to_location_id)
        VALUES (#{adjustment_no}, #{goods_id}, #{batch_id}, #{quantity}, #{from_warehouse_id}, #{from_zone_id}, #{from_location_id}, #{to_warehouse_id}, #{to_zone_id}, #{to_location_id})
    </insert>

    <update id="update" parameterType="com.neuedu.pmf.entity.AdjustmentOrderDetail">
        UPDATE adjustment_order_detail
        <set>
            <if test="adjustment_no != null">adjustment_no = #{adjustment_no},</if>
            <if test="goods_id != null">goods_id = #{goods_id},</if>
            <if test="batch_id != null">batch_id = #{batch_id},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="from_warehouse_id != null">from_warehouse_id = #{from_warehouse_id},</if>
            <if test="from_zone_id != null">from_zone_id = #{from_zone_id},</if>
            <if test="from_location_id != null">from_location_id = #{from_location_id},</if>
            <if test="to_warehouse_id != null">to_warehouse_id = #{to_warehouse_id},</if>
            <if test="to_zone_id != null">to_zone_id = #{to_zone_id},</if>
            <if test="to_location_id != null">to_location_id = #{to_location_id},</if>
        </set>
        WHERE detail_id = #{detail_id}
    </update>

    <delete id="deleteById">
        DELETE FROM adjustment_order_detail WHERE detail_id = #{detail_id}
    </delete>

    <select id="findByAdjustmentNo" resultMap="AdjustmentOrderDetailMap">
        SELECT * FROM adjustment_order_detail WHERE adjustment_no = #{adjustment_no}
    </select>

    <delete id="deleteByAdjustmentNo">
        DELETE FROM adjustment_order_detail WHERE adjustment_no = #{adjustment_no}
    </delete>

    <delete id="deleteByBatchId">
        DELETE FROM adjustment_order_detail WHERE batch_id = #{batch_id}
    </delete>

</mapper>
