<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.pmf.mapper.QualityCheckDetailMapper">

    <resultMap id="QualityCheckDetailMap" type="com.neuedu.pmf.entity.QualityCheckDetail">
        <id column="detail_id" property="detail_id"/>
        <result column="quality_check_no" property="quality_check_no"/>
        <result column="goods_id" property="goods_id"/>
        <result column="batch_id" property="batch_id"/>
        <result column="location_id" property="location_id"/>
        <result column="inspection_result" property="inspection_result"/>
        <result column="defect_reason" property="defect_reason"/>
        <result column="handling_suggestion" property="handling_suggestion"/>
    </resultMap>

    <select id="list" resultMap="QualityCheckDetailMap">
        SELECT * FROM quality_check_detail
    </select>

    <select id="findById" resultMap="QualityCheckDetailMap">
        SELECT * FROM quality_check_detail WHERE detail_id = #{detail_id}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="detail_id">
        INSERT INTO quality_check_detail (quality_check_no, goods_id, batch_id, location_id, inspection_result, defect_reason, handling_suggestion)
        VALUES (#{quality_check_no}, #{goods_id}, #{batch_id}, #{location_id}, #{inspection_result}, #{defect_reason}, #{handling_suggestion})
    </insert>

    <update id="update" parameterType="com.neuedu.pmf.entity.QualityCheckDetail">
        UPDATE quality_check_detail
        <set>
            <if test="quality_check_no != null">quality_check_no = #{quality_check_no},</if>
            <if test="goods_id != null">goods_id = #{goods_id},</if>
            <if test="batch_id != null">batch_id = #{batch_id},</if>
            <if test="location_id != null">location_id = #{location_id},</if>
            <if test="inspection_result != null">inspection_result = #{inspection_result},</if>
            <if test="defect_reason != null">defect_reason = #{defect_reason},</if>
            <if test="handling_suggestion != null">handling_suggestion = #{handling_suggestion},</if>
        </set>
        WHERE detail_id = #{detail_id}
    </update>

    <delete id="deleteById">
        DELETE FROM quality_check_detail WHERE detail_id = #{detail_id}
    </delete>

</mapper>
