<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.pmf.mapper.ZoneMapper">

    <resultMap id="ZoneMap" type="com.neuedu.pmf.entity.Zone">
        <id column="zone_id" property="zone_id"/>
        <result column="zone_name" property="zone_name"/>
        <result column="warehouse_id" property="warehouse_id"/>
        <result column="total_slots" property="total_slots"/>
        <result column="available_slots" property="available_slots"/>
        <result column="description" property="description"/>
    </resultMap>

    <select id="list" resultMap="ZoneMap">
        SELECT * FROM `zone`
    </select>

    <select id="findById" resultMap="ZoneMap">
        SELECT * FROM `zone` WHERE zone_id = #{zone_id}
    </select>

    <insert id="save" useGeneratedKeys="true" keyProperty="zone_id">
        INSERT INTO `zone` (zone_name, warehouse_id, total_slots, available_slots, description)
        VALUES (#{zone_name}, #{warehouse_id}, #{total_slots}, #{available_slots}, #{description})
    </insert>

    <update id="update" parameterType="com.neuedu.pmf.entity.Zone">
        UPDATE `zone`
        <set>
            <if test="zone_name != null">zone_name = #{zone_name},</if>
            <if test="warehouse_id != null">warehouse_id = #{warehouse_id},</if>
            <if test="total_slots != null">total_slots = #{total_slots},</if>
            <if test="available_slots != null">available_slots = #{available_slots},</if>
            <if test="description != null">description = #{description},</if>
        </set>
        WHERE zone_id = #{zone_id}
    </update>

    <delete id="deleteById">
        DELETE FROM `zone` WHERE zone_id = #{zone_id}
    </delete>

</mapper>
