<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.neuedu.pmf.mapper.OutboundOrderHeadMapper">

    <resultMap id="OutboundOrderHeadMap" type="com.neuedu.pmf.entity.OutboundOrderHead">
        <id column="outbound_no" property="outbound_no"/>
        <result column="outbound_type" property="outbound_type"/>
        <result column="order_status" property="order_status"/>
        <result column="operator_id" property="operator_id"/>
        <result column="priority" property="priority"/>
        <result column="deadline" property="deadline"/>
        <result column="outbound_time" property="outbound_time"/>
        <result column="remark" property="remark"/>
        <result column="create_time" property="create_time"/>
    </resultMap>

    <select id="list" resultMap="OutboundOrderHeadMap">
        SELECT * FROM outbound_order_head
    </select>

    <select id="findById" resultMap="OutboundOrderHeadMap">
        SELECT * FROM outbound_order_head WHERE outbound_no = #{outbound_no}
    </select>

    <insert id="save">
        INSERT INTO outbound_order_head (outbound_no, outbound_type, order_status, operator_id, priority, deadline, outbound_time, remark, create_time)
        VALUES (#{outbound_no}, #{outbound_type}, #{order_status}, #{operator_id}, #{priority}, #{deadline}, #{outbound_time}, #{remark}, #{create_time})
    </insert>

    <update id="update" parameterType="com.neuedu.pmf.entity.OutboundOrderHead">
        UPDATE outbound_order_head
        <set>
            <if test="outbound_type != null">outbound_type = #{outbound_type},</if>
            <if test="order_status != null">order_status = #{order_status},</if>
            <if test="operator_id != null">operator_id = #{operator_id},</if>
            <if test="priority != null">priority = #{priority},</if>
            <if test="deadline != null">deadline = #{deadline},</if>
            <if test="outbound_time != null">outbound_time = #{outbound_time},</if>
            <if test="remark != null">remark = #{remark},</if>
        </set>
        WHERE outbound_no = #{outbound_no}
    </update>

    <delete id="deleteById">
        DELETE FROM outbound_order_head WHERE outbound_no = #{outbound_no}
    </delete>

    <select id="findTodayOutboundNos" resultType="string">
        SELECT outbound_no FROM outbound_order_head WHERE outbound_no LIKE #{prefix}
    </select>

</mapper>
